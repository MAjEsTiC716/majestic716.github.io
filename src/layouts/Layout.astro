---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Noah Garcia | Software Engineer',
  description = 'Portfolio for Noah Garcia, a software engineer focused on backend systems, automation, testing, cloud infrastructure, and interactive web experiences.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#bfe8d7" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.site?.toString()} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=IBM+Plex+Mono:wght@400;500&display=swap');

  :root {
    --seafoam-1: #f4fffb;
    --seafoam-2: #dff8ee;
    --seafoam-3: #bfe8d7;
    --seafoam-4: #94d3b7;
    --seafoam-5: #2f5d50;
    --ink: #101312;
    --ink-soft: #26302c;
    --line: rgba(16, 19, 18, 0.16);
    --line-strong: rgba(16, 19, 18, 0.32);
    --surface: rgba(255, 255, 255, 0.62);
    --surface-strong: rgba(255, 255, 255, 0.78);
    --shadow: 0 22px 60px rgba(19, 30, 26, 0.14);
    --radius-xl: 32px;
    --radius-lg: 24px;
    --radius-md: 18px;
    --max-width: 1180px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-width: 320px;
    color: var(--ink);
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.85), transparent 38%),
      radial-gradient(circle at top right, rgba(148, 211, 183, 0.48), transparent 24%),
      linear-gradient(180deg, var(--seafoam-2) 0%, #caefe0 38%, #eafaf3 100%);
    font-family: 'Space Grotesk', 'Avenir Next', 'Segoe UI', sans-serif;
    line-height: 1.55;
  }

  body::before {
    position: fixed;
    inset: 0;
    z-index: -1;
    background-image:
      linear-gradient(rgba(16, 19, 18, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(16, 19, 18, 0.04) 1px, transparent 1px);
    background-size: 32px 32px;
    content: '';
    opacity: 0.42;
    pointer-events: none;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  button,
  input {
    font: inherit;
  }

  .shell {
    width: min(calc(100% - 2rem), var(--max-width));
    margin: 0 auto;
  }

  .section {
    padding: 4.5rem 0;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 1rem;
    color: var(--seafoam-5);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .eyebrow::before {
    width: 2.75rem;
    height: 1px;
    background: currentColor;
    content: '';
  }

  .section-heading {
    margin: 0 0 1rem;
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
  }

  .section-copy {
    max-width: 62ch;
    margin: 0;
    color: var(--ink-soft);
    font-size: 1.04rem;
  }

  .panel {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--surface);
    box-shadow: var(--shadow);
    backdrop-filter: blur(10px);
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.66);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.8rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 3rem;
    padding: 0.8rem 1.2rem;
    border: 1px solid var(--ink);
    border-radius: 999px;
    background: var(--ink);
    color: var(--seafoam-1);
    font-weight: 600;
    transition:
      transform 180ms ease,
      background 180ms ease,
      color 180ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button.secondary {
    background: transparent;
    color: var(--ink);
  }

  .grid-2 {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .grid-3 {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  @media (max-width: 900px) {
    .section {
      padding: 3.75rem 0;
    }

    .grid-2,
    .grid-3 {
      grid-template-columns: 1fr;
    }
  }
</style>
